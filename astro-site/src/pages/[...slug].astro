---
import { getCollection, render } from "astro:content";
import DocLayout from "../layouts/DocLayout.astro";
import { getAllPages, getSection } from "../lib/nav";

export async function getStaticPaths() {
  const allPages = getAllPages();
  const entries = await getCollection("docs");

  return allPages.map((page) => {
    const entry = entries.find((e) => e.id === page.contentId);
    return {
      params: { slug: page.slug },
      props: { page, entry },
    };
  });
}

const { page, entry } = Astro.props;

if (!entry) {
  return Astro.redirect("/404");
}

const { Content, headings } = await render(entry);
const section = getSection(page.sectionPath);
const currentPath = `/${page.slug}/`;
const tabPath = page.sectionPath + "/";
---

<DocLayout title={page.title} headings={headings} currentPath={tabPath}>
  <Content />
</DocLayout>
