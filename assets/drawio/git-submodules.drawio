        <mxCell id="arr-cb" edge="1" parent="1" source="c3-e" target="c2-e" style="endArrow=classic;html=1;strokeColor=#444441;strokeWidth=1;endFill=1;endSize=6;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pinned label on commit B -->
        <mxCell id="label-pinned" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;fontSize=11;fontStyle=2;fontColor=#2563EB;fontFamily=Helvetica;" value="pinned here" vertex="1">
          <mxGeometry x="370" y="112" width="76" height="18" as="geometry" />
        </mxCell>

        <!-- Dashed arrow: pin → commit B -->
        <mxCell id="arr-pin" edge="1" parent="1" source="box-pin" target="c2-e" style="endArrow=classic;html=1;strokeColor=#2563EB;strokeWidth=1;endFill=1;endSize=6;dashed=1;dashPattern=4 3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Note: not copied -->
        <mxCell id="label-note" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#5F5E5A;fontFamily=Helvetica;" value="files not copied&lt;br&gt;until init + update" vertex="1">
          <mxGeometry x="350" y="160" width="130" height="36" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
