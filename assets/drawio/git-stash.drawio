<mxfile host="app.diagrams.net">
  <diagram id="stash" name="Stash workflow">
    <mxGraphModel dx="800" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="320" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Background card -->
        <mxCell id="bg-card" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D3D1C7;strokeWidth=0.5;shadow=0;arcSize=5;" value="" vertex="1">
          <mxGeometry x="10" y="10" width="670" height="290" as="geometry" />
        </mxCell>

        <!-- Working tree box -->
        <mxCell id="box-worktree" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;strokeWidth=0.5;shadow=0;fontSize=12;fontStyle=1;fontColor=#1E40AF;fontFamily=Helvetica;verticalAlign=top;align=center;spacingTop=8;arcSize=10;" value="Working Tree" vertex="1">
          <mxGeometry x="40" y="40" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="label-wt" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#5F5E5A;fontFamily=Helvetica;" value="uncommitted changes" vertex="1">
          <mxGeometry x="40" y="72" width="120" height="28" as="geometry" />
        </mxCell>

        <!-- Stash box -->
        <mxCell id="box-stash" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF9C3;strokeColor=#CA8A04;strokeWidth=0.5;shadow=0;fontSize=12;fontStyle=1;fontColor=#854D0E;fontFamily=Helvetica;verticalAlign=top;align=center;spacingTop=8;arcSize=10;" value="Stash" vertex="1">
          <mxGeometry x="280" y="40" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="label-stash" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#5F5E5A;fontFamily=Helvetica;" value="saved snapshots" vertex="1">
          <mxGeometry x="280" y="72" width="120" height="28" as="geometry" />
        </mxCell>

        <!-- Clean tree box -->
        <mxCell id="box-clean" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;strokeWidth=0.5;shadow=0;fontSize=12;fontStyle=1;fontColor=#15803D;fontFamily=Helvetica;verticalAlign=top;align=center;spacingTop=8;arcSize=10;" value="Clean Tree" vertex="1">
          <mxGeometry x="520" y="40" width="120" height="70" as="geometry" />
        </mxCell>
        <mxCell id="label-clean" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#5F5E5A;fontFamily=Helvetica;" value="safe to switch branch" vertex="1">
          <mxGeometry x="520" y="72" width="120" height="28" as="geometry" />
        </mxCell>

        <!-- Arrow: push (worktree → stash) -->
        <mxCell id="arr-push" edge="1" parent="1" source="box-worktree" target="box-stash" style="endArrow=classic;html=1;strokeColor=#444441;strokeWidth=1;endFill=1;endSize=6;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="label-push" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=bottom;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Courier New;" value="git stash push" vertex="1">
          <mxGeometry x="160" y="42" width="120" height="20" as="geometry" />
        </mxCell>

        <!-- Arrow: result (stash → clean) -->
        <mxCell id="arr-clean" edge="1" parent="1" source="box-stash" target="box-clean" style="endArrow=classic;html=1;strokeColor=#444441;strokeWidth=1;endFill=1;endSize=6;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: pop (stash → worktree, below) -->
        <mxCell id="arr-pop" edge="1" parent="1" source="box-stash" target="box-worktree" style="endArrow=classic;html=1;strokeColor=#444441;strokeWidth=1;endFill=1;endSize=6;edgeStyle=orthogonalEdgeStyle;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="340" y="150" />
              <mxPoint x="100" y="150" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="label-pop" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Courier New;" value="git stash pop" vertex="1">
          <mxGeometry x="160" y="150" width="120" height="20" as="geometry" />
        </mxCell>

        <!-- Command reference -->
        <mxCell id="ref-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#2C2C2A;fontFamily=Helvetica;" value="Commands:" vertex="1">
          <mxGeometry x="40" y="190" width="100" height="24" as="geometry" />
        </mxCell>

        <mxCell id="ref-1" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Helvetica;" value="&lt;font face=&quot;Courier New&quot;&gt;git stash push -m &quot;label&quot;&lt;/font&gt; — save changes with a description" vertex="1">
          <mxGeometry x="40" y="214" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ref-2" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Helvetica;" value="&lt;font face=&quot;Courier New&quot;&gt;git stash list&lt;/font&gt; — list all stash entries" vertex="1">
          <mxGeometry x="40" y="234" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ref-3" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Helvetica;" value="&lt;font face=&quot;Courier New&quot;&gt;git stash pop&lt;/font&gt; — restore and remove from stash" vertex="1">
          <mxGeometry x="40" y="254" width="400" height="20" as="geometry" />
        </mxCell>
        <mxCell id="ref-4" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=0;fontColor=#2C2C2A;fontFamily=Helvetica;" value="&lt;font face=&quot;Courier New&quot;&gt;git stash push -u&lt;/font&gt; — include untracked files" vertex="1">
          <mxGeometry x="40" y="274" width="400" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
